    <snippet id="env_vars">
        <chapter title="Environment Variables" id="environment_variables" collapsible="true" default-state="collapsed">
            <deflist type="wide" sorted="asc">
                <def title="OPENBLAS_NUM_THREADS">
                    Should always be 1
                </def>
                <def title="PYTORCH_ENABLE_MPS_FALLBACK">
                    Set it to 1 on Mac
                </def>
                <def title="NO_PROXY">
                    'localhost, 127.0.0.1, ::1'
                </def>
                <def title="BASE_DATA_ROOT">
                    <code>/app</code> for production
                </def>
                <def title="WEIGHT_ROOT">
                    <code>/app/models</code> for production, model path
                </def>
                <def title="WEIGHT_UVR5_ROOT">
                    <code>assets/uvr5_weights</code>
                </def>
                <def title="INDEX_ROOT">
                    <code>/app/models</code> for production, index path
                </def>
                <def title="RMVPE_ROOT">
                    <code>assets/rmvpe</code>
                </def>
            </deflist>
        </chapter>
    </snippet>

    <snippet id="env_secret_vars">
        <chapter title="Secret Environment Variables" id="secret_environment_variables" collapsible="true" default-state="collapsed">
            <deflist type="wide" sorted="asc">
                <def title="VC_BUCKET">
                    cloud bucket name; <code>voicerary</code> for production, <code>voicerary-dev</code> for local development
                </def>
                <def title="CF_ACCOUNT_ID">
                    Cloudflare account ID
                </def>
                <def title="CF_DB_WORKER_API_TOKEN">
                    API Token for Cloudflare <code>voicerary-db</code> Worker
                </def>
                <def title="AWS_ACCESS_KEY_ID">
                    Cloudflare R2 Access Key ID
                </def>
                <def title="AWS_SECRET_ACCESS_KEY">
                    Cloudflare R2 Secret Access Key
                </def>
                <def title="APP_ENV">
                    <code>production</code>,
                    <code>staging</code>,
                    <code>development</code>
                </def>
                <def title="MODELS_METADATA_URL">
                    Cloudflare Worker URL to fetch models metadata;
                    <code>https://db.voicerary.app/models/{APP_ENV}</code> for production and staging;
                    for local development base url is <code>http://localhost:8787/</code>
                </def>
                <def title="MODELS_BUCKET">
                    <code>rvc-models</code>
                </def>
                <def title="MODELS_ACCESS_KEY_ID">
                    Cloudflare R2 Access Key ID (readonly access to models bucket)
                </def>
                <def title="MODELS_SECRET_ACCESS_KEY">
                    Cloudflare R2 Secret Access Key (readonly access to models bucket)
                </def>
            </deflist>
        </chapter>
    </snippet>

    <snippet id="github-release">
        <procedure id="gh-release-steps-sequence" title="Create release on GitHub">
            <step>
                Open the voicerary-api <a href="https://github.com/ryurchik/voicerary-api/releases">Releases page</a> on
                GitHub
                and click on a
                <control>Draft a new release</control>
                button:
                <img thumbnail="true" border-effect="line" src="draft-new-release.png" alt="draft new release button"/>
            </step>
            <step>
                <p>Click on
                    <control>Choose a tag</control>
                    dropdown and enter a new tag value that will be created.
                    You will see the list of recent tags, use the next version number available for a new tag.
                </p>
                <tip title="For example:">
                    If last created tag is <code>v0.5</code>, the next one should be <code>v0.5.1</code>
                </tip>
                <p>Make sure that target is set to <code>main</code> and click on
                    <control>Create new tag</control>
                    :
                </p>
                <img border-effect="line" src="new-tag.png" alt="draft new release button"/>
            </step>
            <step>
                <p>
                    Add a title to release, fill description if needed, make sure that
                    <control>Set as a pre-release</control>
                    is checked and click
                    <control>Publish release</control>
                    :
                </p>
                <tip title="Why pre-release?">
                    We want to mark something as released only when production API Endpoint was switched to the new
                    version of voicerary-api Docker image
                </tip>
                <img border-effect="line" src="publish-pre-release.png" alt="publish pre-release"/>
            </step>
            <step>
                <p>
                    That will trigger a new docker image build automatically on the DockerHub side
                </p>
                <p>
                    <emphasis>If you have access to the <a
                            href="https://hub.docker.com/repository/registry-1.docker.io/ryurchik/voicerary/builds">
                        ryurchik/voicerary
                    </a> docker image, you can check a build status for a tag with
                        the same version that you created on GitHub. It takes about 10–15 minutes to build a new image:
                    </emphasis>
                </p>
                <img thumbnail="true" border-effect="line" src="docker-hub-build.png" alt="DockerHub Build"/>
                <tip title="What if I don't have access to the DockerHub repo?">
                    You still can wait for about half an hour for the image to be built and then go to the next step
                </tip>
            </step>
            <step>
                <p>
                    As soon as docker build is succeeded and new image is available,
                    open <a href="https://www.runpod.io/console/serverless/user/endpoint/kwjye1q2t5alv2">RunPod
                    Endpoint</a>
                    and click on 3-dots at the right top, then select
                    <control>New Release</control>;
                    from there you can update and deploy a new voicerary image version to be used by workers:
                </p>
                <tip title="RunPod Environment">Before updating production, you can test new image on
                    <a href="https://www.runpod.io/console/serverless/user/endpoint/flv11xsu312j92">staging API
                        Endpoint</a>
                    if you want
                </tip>
                <img border-effect="line" src="runpod-new-release.png" alt="RunPod new release button"/>
                <img border-effect="line" src="runpod-new-release-dialog.png" alt="RunPod new release dialog"/>
            </step>
            <step>
                <p>Now go back to the voicerary-api <a href="https://github.com/ryurchik/voicerary-api/releases">
                    Releases page</a>
                    and update your release draft. Click on the pencil icon in the top right corner and check
                    <control>Set as the latest release</control>, then click
                    <control>Update release</control>:
                </p>
                <img border-effect="line" src="update-release-draft.png" alt="Update release"/>
                <note title="You're done!">
                    🙌
                </note>
            </step>
        </procedure>
    </snippet>

    <snippet id="before_d1_db_work_snippet">
        <chapter title="Before you start" id="before_d1_db_work">
            <p>Make sure that:</p>
            <list>
                <li><p>
                    you have cloned <a href="https://github.com/ryurchik/voicerary-cloudflare">
                    voicerary-cloudflare</a> repository to your local machine,
                    and you have pulled the latest changes
                </p>
                    <emphasis>Optional: if you do it first time, run <code>yarn</code> or <code>npm install</code></emphasis>
                </li>
                <li>you have installed <a href="https://developers.cloudflare.com/workers/wrangler/install-and-update/">
                    Wrangler</a> cli tool from Cloudflare
                </li>
            </list>
        </chapter>
    </snippet>

    <snippet id="cf-d1-model-active-flag">
        <tip title="Active Flag">
            If you're creating a new model, you might want to set <code>active</code> flag to <control>0</control>.
            Otherwise, your model record will appear in the
            <a href="Cloud-Database.topic#cloudflare_worker">cloud database API response,</a> and if
            it does not exists on <a
                href="https://dash.cloudflare.com/35ffb8490e28826a7367c73da57f6afc/r2/default/buckets/rvc-models">
            rvc-models</a> bucket, API processing will be broken.
            Rule of thumb here is to set model active only after you have
            uploaded model/index files to the cloud storage
        </tip>
    </snippet>

    <snippet id="converted-file-naming">
        <tip title="Example">
            <p>Input: <code>vc/test/K_8.aif</code></p>
            <p>Output: <code>vc/test/K_8_S_Maria_-4_1706472554.wav</code></p>
        </tip>
    </snippet>
